{
  "name": "ekairos",
  "version": "1.22.0",
  "description": "Ekairos - AI Stories and Workflows Runtime",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/e-kairos/ekairos.git",
    "directory": "packages/ekairos"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./dataset": {
      "types": "./dist/dataset.d.ts",
      "import": "./dist/dataset.js",
      "require": "./dist/dataset.js",
      "default": "./dist/dataset.js"
    },
    "./context": {
      "types": "./dist/context.d.ts",
      "import": "./dist/context.js",
      "require": "./dist/context.js",
      "default": "./dist/context.js"
    },
    "./domain": {
      "types": "./dist/domain.d.ts",
      "import": "./dist/domain.js",
      "require": "./dist/domain.js",
      "default": "./dist/domain.js"
    },
    "./agent": {
      "types": "./dist/agent.d.ts",
      "import": "./dist/agent.js",
      "require": "./dist/agent.js",
      "default": "./dist/agent.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js",
      "require": "./dist/runtime.js",
      "default": "./dist/runtime.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "node -e \"require('fs').rmSync('dist', {recursive:true, force:true})\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ekairos/dataset": "workspace:*",
    "@ekairos/domain": "^1.22.0",
    "@ekairos/events": "workspace:*",
    "@instantdb/admin": "0.22.126"
  },
  "devDependencies": {
    "@ekairos/tsconfig": "workspace:*",
    "@types/node": "^24.5.0",
    "typescript": "^5.9.2"
  }
}
